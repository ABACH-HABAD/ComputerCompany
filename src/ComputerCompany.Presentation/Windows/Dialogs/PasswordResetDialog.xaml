<Window x:Class="ComputerCompany.Presentation.Windows.Dialogs.PasswordResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany.Presentation.Windows.Dialogs"
        xmlns:helpers="clr-namespace:ComputerCompany.Presentation.Services.Helpers"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Смена пароля" Height="300" Width="380">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Введите старый пароль:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Bottom"/>
        <PasswordBox
        helpers:PasswordBoxHelper.BindPassword="True"
        helpers:PasswordBoxHelper.BoundPassword="{Binding OldPassword}"
        Style="{StaticResource AdminRulePasswordBox}"
        Grid.Row="1"
        Name="OldPassword" 
        VerticalAlignment="Stretch" 
        HorizontalAlignment="Stretch"
        Margin="10,5,10,5"
        FontSize="18"/>
        <TextBlock Grid.Row="2" Text="Введите новый пароль:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Bottom"/>
        <PasswordBox
        helpers:PasswordBoxHelper.BindPassword="True"
        helpers:PasswordBoxHelper.BoundPassword="{Binding NewPassword}"
        Grid.Row="3"
        Name="NewPassword" 
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        Margin="10,5,10,5" 
        FontSize="18"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button
            Command="{Binding AcceptCommand}"
            x:Name="Accept" 
            Content="Подтвердить"
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch" 
            FontSize="20" />
            <Button
            Command="{Binding DenyCommand}"
            x:Name="Cancel"
            Grid.Column="1"
            Content="Отмена"
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch" 
            FontSize="20" />
        </Grid>
    </Grid>
</Window>
