<UserControl x:Class="ComputerCompany.Presentation.UserControls.WelcomeUserControls.RegistrationUserControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompany.Presentation.UserControls.WelcomeUserControls"
      xmlns:helpers="clr-namespace:ComputerCompany.Presentation.Services.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="700"
      >

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <Label Content="Регистрация"/>
        <Label Content="Логин (эл. почта):" HorizontalAlignment="Left" Margin="35,5,0,5"/>
        <TextBox
        Text="{Binding Login}"
        Width="180" 
        Name="Login"/>
        <Label Content="Пароль:"  HorizontalAlignment="Left" Margin="35,5,0,5"/>
        <PasswordBox 
        helpers:PasswordBoxHelper.BindPassword="True"
        helpers:PasswordBoxHelper.BoundPassword="{Binding Password}"
        Width="180" 
        Name="Password"/>
        <Label Content="Повторите пароль:" HorizontalAlignment="Left" Margin="35,5,0,5"/>
        <PasswordBox
        helpers:PasswordBoxHelper.BindPassword="True"
        helpers:PasswordBoxHelper.BoundPassword="{Binding RepeatPassword}"
        Width="180" 
        Name="Password2"/>
        <Button 
        Command="{Binding RegistrationCommand}"
        Name="Registration" 
        Content="Регистрация" 
        Width="200"  Margin="0,25,0,0"/>
        <Button
        Command="{Binding NavigateToAuthorizationCommand}"
        Name="AutorizationButton" 
        Content="Уже есть аккаунт"
        Margin="0,10,0,0" 
        Width="125"  />
    </StackPanel>
</UserControl>
