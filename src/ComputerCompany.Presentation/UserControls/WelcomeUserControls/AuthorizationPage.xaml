<UserControl x:Class="ComputerCompany.Presentation.UserControls.WelcomeUserControls.AuthorizationUserControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="ComputerCompany:Client.UserControls.WelcomeUserControls"
        xmlns:helpers="clr-namespace:ComputerCompany.Presentation.Services.Helpers"
        mc:Ignorable="d"
        Height="400" Width="700" 
        HorizontalAlignment="Center" 
        VerticalAlignment="Center">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Авторизация"  VerticalAlignment="Top"/>
        <Label Content="Логин (эл. почта):" HorizontalAlignment="Left" Margin="35,5,0,5" />
        <TextBox  
        Text="{Binding Login}"
        VerticalAlignment="Top" Width="180" 
        Name="Login"/>
            <Label Content="Пароль:"  VerticalAlignment="Top" HorizontalAlignment="Left" Margin="35,5,0,5" />
            <PasswordBox
            VerticalAlignment="Top" 
            Width="180" 
            helpers:PasswordBoxHelper.BindPassword="True"
            helpers:PasswordBoxHelper.BoundPassword="{Binding Password}"
            />

        <Button 
        Command="{Binding AuthorizationCommand}"
        CommandParameter="{Binding ElementName=PasswordControl}"
        Name="Authorization"
        Content="Авторизация" 
        Margin="0,80,0,0" 
        Width="200"  />
        <Button 
        Command="{Binding NavigateToRegistrationCommand}"
        Name="Registration"
        Content="Создать аккаунт"
        Margin="0,10,0,0" 
        Width="125"  />

        </StackPanel>
</UserControl>
