<UserControl x:Class="ComputerCompany.Presentation.UserControls.ClientBuildUserControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompany.Presentation.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="350" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <TextBlock VerticalAlignment="Center" Margin="10,0,10,0" FontSize="25">Сборка ПК</TextBlock>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <RadioButton 
                IsChecked="{Binding ConsultationMode}"
                Name="ConsultationRB"
                GroupName="AssemblyGroup" 
                Content="Подбор комплектующих" 
                Margin="5,5,5,5" FontSize="18" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" />
                <RadioButton 
                IsChecked="{Binding IKnowWhatIWantMode}"
                Name="IKnowWhatIWantRB" 
                GroupName="AssemblyGroup" 
                Content="Я знаю чего хочу" 
                Grid.Column="1" Margin="5,5,5,5"
                FontSize="18" HorizontalAlignment="Center" 
                VerticalAlignment="Center" />
            </Grid>
            <Grid
                Style="{StaticResource ConsultationModeGrid}"
                Name="Consultation" Grid.Row="1" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock 
                    Text="Желаемая стоимость комплектующих" 
                    FontSize="18" 
                    VerticalAlignment="Center"
                    Margin="5,0,5,0"/>
                    <TextBox 
                    FontSize="18"
                    Text="{Binding DesiredCost}"
                    Grid.Column="1" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Center" 
                    Margin="2,2,5,2"/>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="5*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Пожелания:" FontSize="18" VerticalAlignment="Center" Margin="5,0,5,0"/>
                    <TextBox 
                    Text="{Binding Wishes}"
                    Grid.Row="1" 
                    TextWrapping="Wrap"
                    FontSize="18"
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Top" 
                    Margin="5,5,5,5"/>
                </Grid>
            </Grid>
            <Grid 
            Style="{StaticResource IKnowWhatIWantModeGrid}"
            Name="INowWhatIWant" Grid.Row="1" Visibility="Collapsed">
                
            </Grid>
            <Button 
            Command="{Binding OrderAssemblyCommand}"
            Name="OrderAssembly"
            Grid.Row="2"
            FontSize="18"
            Content="Заказать сборку"
            Margin="0,5,10,5" 
            HorizontalAlignment="Right" 
            VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>

