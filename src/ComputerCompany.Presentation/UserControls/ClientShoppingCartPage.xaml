<UserControl x:Class="ComputerCompany.Presentation.UserControls.ClientShoppingCartUserControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompany.Presentation.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="350" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="53*"/>
            <ColumnDefinition Width="26*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Margin="10,0,10,0" FontSize="25"> 🛒 Корзина</TextBlock>
            <Button 
            Command="{Binding ClearBasketCommand}"
            x:Name="Clear" 
            Content="Отчистить корзину" 
            VerticalAlignment="Center" 
            FontSize="25" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="5,5,5,5">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="Red"/>
                    <GradientStop Color="Red" Offset="1"/>
                    <GradientStop Color="Blue" Offset="0.333"/>
                    <GradientStop Color="Lime" Offset="0.667"/>
                </LinearGradientBrush>
            </Grid.Background>
            <ScrollViewer Name="scroll" CanContentScroll="True" Margin="2,2,2,2">
                <ItemsControl
                ItemsSource="{Binding Products}"
                Name="PurchaseList"
                Background="#FF252525">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,10,10,0" Height="100" VerticalAlignment="Top">
                                <Grid.Background>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                        <LinearGradientBrush.RelativeTransform>
                                            <TransformGroup>
                                                <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </LinearGradientBrush.RelativeTransform>
                                        <GradientStop Color="Red"/>
                                        <GradientStop Color="Red" Offset="1"/>
                                        <GradientStop Color="Blue" Offset="0.333"/>
                                        <GradientStop Color="Lime" Offset="0.667"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <Grid Margin="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Vertical" Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"   Margin="5" FontSize="20"/>
                                        <TextBlock Text="{Binding Description}"   Margin="5" TextWrapping="Wrap" FontSize="18"/>
                                    </StackPanel>
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <WrapPanel Orientation="Horizontal">
                                            <TextBlock Text="Цена:" TextWrapping="Wrap" Padding="0,5,5,0" FontSize="20"/>
                                            <TextBlock Text="{Binding Price}" TextWrapping="Wrap" Padding="0,5,5,0" FontSize="20"/>
                                            <TextBlock Text="рублей" TextWrapping="Wrap" Padding="0,5,5,0" FontSize="20"/>
                                        </WrapPanel>
                                        <Button 
                                        Command="{Binding Path=DataContext.DeleteProductFromShoppingCartCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Grid.Row="1" 
                                                Name="DeleteButton"
                                                Content="Удалить" 
                                                VerticalAlignment="Bottom" 
                                                FontSize="20"
                                                HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Column="1" Grid.Row="1" Margin="5,5,0,0">
            <TextBlock Text="Итого:" FontSize="20" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Total}" x:Name="Total" FontSize="20" HorizontalAlignment="Left" Margin="5,5,5,5"/>
                <TextBlock Text="рублей" FontSize="20" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            </WrapPanel>
            <Button 
            Command="{Binding CardPayCommand}"
            x:Name="CardPayButton"
            Content="Оплатить картой"
            VerticalAlignment="Center"
            FontSize="20" Margin="5,5,5,5"
            HorizontalAlignment="Left"/>
            <Button
            Command="{Binding QrPayCommand}"
            x:Name="QRCodePayButton"
            Content="Оплатить через СБП" 
            VerticalAlignment="Center" FontSize="20"
            Margin="5,5,5,5"
            HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</UserControl>
