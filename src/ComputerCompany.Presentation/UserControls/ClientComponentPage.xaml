<UserControl x:Class="ComputerCompany.Presentation.UserControls.ClientComponentUserControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompany.Presentation.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <StackPanel VerticalAlignment="Center" Margin="10,10,10,10" Orientation="Horizontal">
            <TextBlock Text="Выберите тип компонента:" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ComboBox 
            Foreground="Black"
            ItemsSource="{Binding ComponentsTypes}"
            SelectedItem="{Binding SelectedComponentType}"
            SelectionChanged="DataBaseSelector_SelectionChanged"
            Name="DataBaseSelector" 
            Width="250"
            Margin="10,0,0,0" 
            HorizontalAlignment="Center"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="10,10,10,10">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Red" Offset="0"/>
                    <GradientStop Color="Blue" Offset="0.333"/>
                    <GradientStop Color="Lime" Offset="0.667"/>
                    <GradientStop Color="Red" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Margin="1,1,1,1">
                <ScrollViewer Name="scroll" CanContentScroll="True" >
                    <DataGrid x:Name="ComponentsDataGrid" 
                              AutoGenerateColumns="False" 
                              ItemsSource="{Binding ComponentsTable}" 
                              CanUserAddRows="False">
                        <DataGrid.Resources>
                            <Style x:Key="EditButtonStyle" 
                                   TargetType="Button">
                                <Setter Property="Background" Value="#FF303030"/>
                                <Setter Property="BorderBrush" >
                                    <Setter.Value>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="Red"/>
                                            <GradientStop Color="Red" Offset="1"/>
                                            <GradientStop Color="Blue" Offset="0.333"/>
                                            <GradientStop Color="Lime" Offset="0.667"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Background="Transparent">
                                                <Border x:Name="border"
                                                        CornerRadius="5" 
                                                        Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#40000000"/>
                                                    </Border.Effect>
                                                </Border>
                                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF404040"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF606060"/>
                                                    <Setter TargetName="border" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Color="#40000000"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountType}" Value="Admin">
                                        <Setter Property="Background" Value="#FF464646"/>
                                        <Setter Property="Foreground" Value="#FFC85F5F"/>
                                        <Setter Property="BorderBrush" Value="#FFC85F5F"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="ToolTip" Value="Нельзя изменить данный аккаунт"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}"/>
                            <DataGridTextColumn Header="Модель" Binding="{Binding Model}"/>
                            <DataGridTemplateColumn x:Name="Actions" Header="Действия" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                        Command="{Binding Path=DataContext.AddToBasketCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Content="В корзину" 
                                                Style="{StaticResource EditButtonStyle}"
                                                x:Name="BuyButton"
                                                Margin="5" Height="22"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
