<UserControl x:Class="ComputerCompanyClasses.RegistrationUserControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompanyClasses"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="700">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <Label Content="Регистрация"/>
        <Label Content="Логин (эл. почта):" HorizontalAlignment="Left" Margin="35,5,0,5"/>
        <TextBox Width="120" Name="Login"/>
        <Label Content="Пароль:"  HorizontalAlignment="Left" Margin="35,5,0,5"/>
        <PasswordBox Width="120" Name="Password"/>
        <Label Content="Повторите пароль:" HorizontalAlignment="Left" Margin="35,5,0,5"/>
        <PasswordBox Width="120" Name="Password2"/>
        <Button Name="Registration" Content="Регистрация" Width="200" Height="25" Margin="0,25,0,0" Click="Registration_Click"/>
        <Button Name="AutorizationButton" Content="Уже есть аккаунт" Margin="0,10,0,0" Width="125" Height="25" Click="Authorization_Click"/>
    </StackPanel>
</UserControl>
