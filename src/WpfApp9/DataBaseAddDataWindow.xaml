<Window x:Class="ComputerCompany.DataBaseAddDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="DataBaseAddDataWindow" Height="300" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel  x:Name="AllFields" Margin="5,5,5,5">
            <Grid x:Name="Model" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Модель" FontSize="20"/>
                <TextBox x:Name="ModelText" FontSize="20" Width="250" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Socket" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock  Text="Сокет" FontSize="20"/>
                <TextBox x:Name="SocketText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="ModelCore" Visibility="Hidden"  Height="0" Margin="0">
                <TextBlock  Text="Видеоядро" FontSize="20"/>
                <TextBox x:Name="ModelCoreText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Videomemory" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock x:Name="VideomemoryText" Text="Видеопамять" FontSize="20"/>
                <TextBox FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Size" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Объём" FontSize="20"/>
                <TextBox x:Name="SizeText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Type" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Тип" FontSize="20"/>
                <TextBox x:Name="TypeText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Frequency" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Частота" FontSize="20"/>
                <TextBox x:Name="FrequencyText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Chipset" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Чипсет" FontSize="20"/>
                <TextBox x:Name="ChipsetText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Power" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Энергия" FontSize="20"/>
                <TextBox x:Name="PowerText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="FromFactor" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Формафактор" FontSize="20"/>
                <TextBox x:Name="FromFactorText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Certification" Visibility="Hidden" Height="0" Margin="0">
                <TextBlock Text="Сертификация" FontSize="20"/>
                <TextBox x:Name="CertificationText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Price" Margin="5" Height="23">
                <TextBlock Text="Цена" FontSize="20"/>
                <TextBox x:Name="PriceText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="Count" Margin="5" Height="23">
                <TextBlock Text="Количество" FontSize="20"/>
                <TextBox x:Name="CountText" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Accept" Content="Подтвердить" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Accept_Click"/>
            <Button x:Name="Delete" Grid.Column="1" Content="Удалить" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Delete_Click"/>
            <Button x:Name="Cancel" Grid.Column="2" Content="Отмена" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
