<Window x:Class="ComputerCompany.DeleteAccount"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany"
        ResizeMode="NoResize"
        mc:Ignorable="d"
        Title="Удаление аккаунта" Height="300" Width="525">
    <Grid>
        <StackPanel HorizontalAlignment="Center" Margin="10,10,10,10">
            <TextBlock Text="Вы точно хотите удалить аккаунт?" FontSize="25" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            <TextBlock Text="Для удаления аккаунта введите пароль" Margin="0,15,0,0" HorizontalAlignment="Center" FontSize="20"/>
            <PasswordBox x:Name="ConfrimPassword" FontSize="20" Margin="5,20,5,0" Height="30" VerticalAlignment="Top" HorizontalAlignment="Stretch"/>
            <Grid Margin="0,10,0,0" Height="45">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="Confirm" Content="Подтвердить" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Margin="10,5,10,5" Click="Confirm_Click" />
                <Button x:Name="Cancel" Content="Отменить" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Margin="10,5,10,5" Click="Cancel_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
