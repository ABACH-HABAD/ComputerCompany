<UserControl x:Class="ComputerCompanyClasses.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompanyClasses"
      mc:Ignorable="d" 
      d:DesignHeight="350" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="13*"/>
                <RowDefinition Height="4*"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="5,5,5,5">
                <TextBlock x:Name="AccountName" Text="Имя аккаунта" FontSize="30" Margin="5,5,5,5"/>
                <TextBlock x:Name="Status" Text="Статус" FontSize="18" Margin="5,5,5,5"/>
                <Button Name="ChangeDisplayName" Content="Изменить имя профиля" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5" Click="ChangeDisplayName_Click"/>
                <Button Content="Мои заказы" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5"/>
                <Button Content="История заказов" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5"/>
            </StackPanel>
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                <Button x:Name="Logout" Content="Выйти" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5" Click="Logout_Click"/>
                <Button x:Name="DeleteAccount" Content="Удалить аккаунт" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5" Click="DeleteAccount_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="21*"/>
                <RowDefinition Height="13*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Bottom">
                    <TextBlock Text="Оставить отзыв:" FontSize="18" Margin="5,5,5,5"/>
                    <TextBlock x:Name="Stars" Text="★☆☆☆☆" FontSize="18" Margin="5,5,5,5" HorizontalAlignment="Left"/>
                    <Slider x:Name="StarSlider" Width="{Binding ElementName=Stars, Path=Width}" Maximum="5" Minimum="1" ValueChanged="Slider_ValueChanged"></Slider>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <StackPanel Margin="10,10,10,10" Width="175" HorizontalAlignment="Right">
                        <Image x:Name="ProfileImage" Source="/Resources/Images/WelcomePC1.png" Stretch="Fill" Width="150" Height="150" HorizontalAlignment="Center" Margin="5,5,5,5"/>
                        <Button x:Name="ChangeImage" Content="Изменить фото" HorizontalAlignment="Stretch" FontSize="18" Margin="5,5,5,5" Click="ChangeImage_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="ReviewText" Grid.Row="0" HorizontalAlignment="Stretch" Margin="5,5,5,0" TextWrapping="Wrap"/>
                <Button  Grid.Row="1" x:Name="Send" Content="Отправить" HorizontalAlignment="Right" Margin="0,0,10,5" VerticalAlignment="Bottom" Height="20" Width="70" Click="Send_Click"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
