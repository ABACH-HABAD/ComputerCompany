<Window x:Class="ComputerCompanyClasses.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompanyClasses"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Информационная система «Компьютерная компания» — приветственное окно"
         Height="450" Width="600" MinWidth="600" MinHeight="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="6*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Компьютерная компания" FontFamily="Arial Black" FontSize="40" Foreground="Black" TextWrapping="Wrap" TextAlignment="Center" FlowDirection="RightToLeft" Margin="0,0,0,0" Height="61">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="Red"/>
                    <GradientStop Color="Red" Offset="1"/>
                    <GradientStop Color="Blue" Offset="0.333"/>
                    <GradientStop Color="Lime" Offset="0.667"/>
                </LinearGradientBrush>
            </TextBlock.Background>
        </TextBlock>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="11*"/>
            </Grid.ColumnDefinitions>
            <Image Source="Resources/Images/WelcomePC4.png" Name="WelcomeImage" Grid.Column="0" Stretch="Fill"/>
            <Frame Margin="20,20,20,20" x:Name="WelcomeUserControl" Grid.Column="1" NavigationUIVisibility="Hidden"></Frame>
        </Grid>
    </Grid>
</Window>
