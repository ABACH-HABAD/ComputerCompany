<Window x:Class="ComputerCompany.Presentation.Windows.Dialogs.ChangeDisplayName"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany.Presentation.Windows.Dialogs"
        ResizeMode="NoResize"
        mc:Ignorable="d"
        Title="Смена" 
        Height="175" Width="400">
    <Grid>
        <StackPanel>
            <TextBlock
            FontSize="20"
            Name="FirstNameLable" Text="{Binding ParametrName}" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            <TextBox 
            Text="{Binding ParametrValue}"
            Name="FirstName" 
            FontSize="20"
            MinHeight="32"
            HorizontalAlignment="Stretch" Margin="5,0,5,0"/>
            <Grid Margin="0,10,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button 
                FontSize="20"
                Command="{Binding AcceptCommand}"
                Name="Accept" 
                Content="Применить"
                Grid.Column="0" 
                Margin="5,5,5,5"
                HorizontalAlignment="Stretch"/>
                <Button 
                FontSize="20"
                Command="{Binding DenyCommand}"
                Name="Declare"
                Content="Отменить"
                Grid.Column="1"
                Margin="5,5,5,5"
                HorizontalAlignment="Stretch"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
