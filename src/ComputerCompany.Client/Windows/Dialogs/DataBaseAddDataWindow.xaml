<Window x:Class="ComputerCompany.Presentation.Windows.Dialogs.DataBaseAddDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany.Presentation.Windows.Dialogs"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="DataBaseAddDataWindow" Height="400" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer>
            <StackPanel  x:Name="AllFields">
                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="debug:"/>
                    <TextBlock Text="{Binding Mode}"/>
                </StackPanel>
                <Grid x:Name="DisplayName" Margin="5">
                    <TextBlock Text="Название" FontSize="20"/>
                    <TextBox  Text="{Binding Name}"  MinWidth="350" FontSize="20"  HorizontalAlignment="Right"  VerticalAlignment="Center"/>
                </Grid>
                <Grid x:Name="Description" Margin="5">
                    <TextBlock Text="Описание" FontSize="20"/>
                    <TextBox Text="{Binding Description}" MinWidth="350" TextWrapping="Wrap" MaxHeight="100"  FontSize="20" Width="250" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Price" Margin="5" >
                    <TextBlock Text="Цена" FontSize="20"/>
                    <TextBox Text="{Binding Price}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Count" Margin="5">
                    <TextBlock Text="Количество" FontSize="20"/>
                    <TextBox Text="{Binding Count}" MinWidth="350"  FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Model" Margin="5">
                    <TextBlock Text="Модель" FontSize="20"/>
                    <TextBox Text="{Binding Model}"  MinWidth="350"  FontSize="20" Width="250" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Socket" Style="{StaticResource SocketProperty}">
                    <TextBlock  Text="Сокет" FontSize="20"/>
                    <TextBox Text="{Binding Socket}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="ModelCore" Style="{StaticResource ModelCoreProperty}">
                    <TextBlock  Text="Видеоядро" FontSize="20"/>
                    <TextBox Text="{Binding ModelCore}"  MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Videomemory" Style="{StaticResource VideomemoryProperty}">
                    <TextBlock x:Name="VideomemoryText" Text="Видеопамять" FontSize="20"/>
                    <TextBox Text="{Binding VideoMemory}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Size" Style="{StaticResource SizeProperty}">
                    <TextBlock Text="Объём" FontSize="20"/>
                    <TextBox Text="{Binding Size}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Type" Style="{StaticResource TypeProperty}">
                    <TextBlock Text="Тип" FontSize="20"/>
                    <TextBox Text="{Binding Type}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Frequency" Style="{StaticResource FrequencyProperty}">
                    <TextBlock Text="Частота" FontSize="20"/>
                    <TextBox Text="{Binding Frequency}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Chipset" Style="{StaticResource ChipsetProperty}">
                    <TextBlock Text="Чипсет" FontSize="20"/>
                    <TextBox Text="{Binding Chipset}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Power" Style="{StaticResource PowerProperty}">
                    <TextBlock Text="Мощность" FontSize="20"/>
                    <TextBox Text="{Binding Power}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="FormFactor" Style="{StaticResource FromFactorProperty}">
                    <TextBlock Text="Формфактор" FontSize="20"/>
                    <TextBox Text="{Binding FormFactor}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
                <Grid x:Name="Certification" Style="{StaticResource CertificationProperty}">
                    <TextBlock Text="Сертификация" FontSize="20"/>
                    <TextBox Text="{Binding Certification}" MinWidth="350" FontSize="20" Width="250" Margin="10,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button 
            Command="{Binding AcceptCommand}"
            x:Name="Accept"
            Content="Подтвердить" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            FontSize="20"/>
            <Button
            Command="{Binding DeleteCommand}"
            x:Name="Delete" 
            Grid.Column="1"
            Content="Удалить" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            FontSize="20" />
            <Button
            Command="{Binding DenyCommand}"
            x:Name="Cancel" 
            Grid.Column="2" 
            Content="Отмена" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" 
            FontSize="20"/>
        </Grid>
    </Grid>
</Window>
