<Window x:Class="ComputerCompany.Presentation.Windows.MusicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany.Presentation.Windows"
        mc:Ignorable="d"
        MinHeight="500"
        MinWidth="500"
        ResizeMode="CanMinimize"
        Title="Музыкальный проигрыватель" Height="500" Width="500"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="25*"/>
        </Grid.ColumnDefinitions>

        <Grid Margin="10,10,10,10" Background="#FF464141" x:Name="ContentGrid">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40">
                ♫</TextBlock>
            <MediaElement Name="mediaPlayer"
                          Source="pack://application:,,,/ComputerCompany;component/Resources/Sounds/song.wav"
                          LoadedBehavior="Stop"
                          UnloadedBehavior="Stop"
                          />
        </Grid>

        <Grid Grid.Column="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid ScrollViewer.CanContentScroll="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="11*"/>
                        <ColumnDefinition Width="25*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Background="#FF252525" Grid.ColumnSpan="2" Margin="0,0,225,0">
                Сейчас играет:
                    </TextBlock>
                    <TextBlock 
                        x:Name ="SongText" 
                        Text="Неизвестен - без названия" 
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        TextTrimming="CharacterEllipsis"
                        Width="200">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="TextTransform"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                        Storyboard.TargetName="TextTransform"
                        Storyboard.TargetProperty="X"
                        From="0" 
                        To="50"
                        Duration="0:0:4"
                        AutoReverse="True"
                        RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </Grid>
                <Grid Grid.Row="1" Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar  Name="SongProgressBar" Margin="0,1,0,1">
                        <ProgressBar.BorderBrush>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                <GradientStop Color="Red"/>
                                <GradientStop Color="Red" Offset="1"/>
                                <GradientStop Color="Blue" Offset="0.333"/>
                                <GradientStop Color="Lime" Offset="0.667"/>
                            </LinearGradientBrush>
                        </ProgressBar.BorderBrush>
                        <ProgressBar.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                <LinearGradientBrush.RelativeTransform>
                                    <TransformGroup>
                                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                        <RotateTransform Angle="0" CenterX="0.5" CenterY="0.5"/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop Color="#FFFF6464"/>
                                <GradientStop Color="#FFFF6464" Offset="1"/>
                                <GradientStop Color="#FF6464FF" Offset="0.32"/>
                                <GradientStop Color="#FF64FF64" Offset="0.667"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    <TextBlock x:Name="Time" Text="04:30" Grid.Column="1" HorizontalAlignment="Right" Width="36"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Slider
                x:Name="VolumeSlider" 
                VerticalAlignment="Center" 
                Margin="10,0,10,0" Value="5"
                Minimum="1">
                    <Slider.BorderBrush>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                            <LinearGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                    <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="Red"/>
                            <GradientStop Color="Red" Offset="1"/>
                            <GradientStop Color="Blue" Offset="0.333"/>
                            <GradientStop Color="Lime" Offset="0.667"/>
                        </LinearGradientBrush>
                    </Slider.BorderBrush>
                </Slider>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Button 
                    Grid.Column="0" 
                    Name="PrevieweSong" 
                    Content="⏪︎" 
                    Height="20" 
                    Margin="0,0,0,0" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="20" />
                    <Button 
                    Grid.Column="1"
                    Name="PlayOrPauseSong" 
                    Content="▷" Height="20" 
                    Margin="0,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" 
                    Width="40"/>
                    <Button 
                    Grid.Column="2" 
                    Name="NextSong" 
                    Content="⏩︎" 
                    Height="20" 
                    Margin="0,0,0,0" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="20"/>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel>
                <StackPanel.Resources>
                    <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Width" Value="80"/>
                        <Setter Property="Height" Value="80"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid>
                                        <Border x:Name="border"
                            CornerRadius="10"
                            Background="#FF303030" 
                            BorderThickness="1">
                                            <Border.BorderBrush>
                                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                    <GradientStop Color="Red" Offset="0"/>
                                                    <GradientStop Color="Blue" Offset="0.333"/>
                                                    <GradientStop Color="Lime" Offset="0.667"/>
                                                    <GradientStop Color="Red" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.BorderBrush>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#40000000"/>
                                            </Border.Effect>
                                        </Border>
                                        <Border x:Name="imageBorder"
                            CornerRadius="10"
                            BorderThickness="1">
                                            <Border.Background>
                                                <ImageBrush Stretch="Fill" 
                                       ImageSource="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                            </Border.Background>
                                        </Border>
                                        <Border x:Name="checkMarkBorder"
                            CornerRadius="5"
                            Width="20" Height="20"
                            Margin="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#7000FF00"
                            BorderBrush="Lime"
                            BorderThickness="2"
                            Visibility="Collapsed">
                                            <Path x:Name="checkMark"
                              Data="M0,5 L5,10 L15,0"
                              Stroke="White"
                              StrokeThickness="2"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                                        </Border>

                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FF404040"/>
                                            <Setter TargetName="imageBorder" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FF606060"/>
                                            <Setter TargetName="imageBorder" Property="Opacity" Value="0.6"/>
                                            <Setter TargetName="border" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Color="#40000000"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="checkMarkBorder" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>
                <ToggleButton Margin="5,5,5,5" Width="80" Height="80"
                              Name="VibeSongs"
                            Style="{StaticResource IconToggleButtonStyle}" 
                            Tag="/Resources/Images/WelcomePC1.png" />
                <ToggleButton Margin="5,5,5,5" Width="80" Height="80"
                              Name="CoolSongs"
                        Style="{StaticResource IconToggleButtonStyle}" 
                        Tag="/Resources/Images/Verycool.png"/>
                <ToggleButton Margin="5,5,5,5" Width="80" Height="80"
                              Name="MLGSongs"
                        Style="{StaticResource IconToggleButtonStyle}" 
                        Tag="/Resources/Images/MLG.png" />
                <ToggleButton Margin="5,5,5,5" Width="80" Height="80"
                              Name="VokaloidSongs"
                        Style="{StaticResource IconToggleButtonStyle}" 
                        Tag="/Resources/Images/Vokaloid.png" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="1" Margin="10,10,10,10">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Red" Offset="0"/>
                    <GradientStop Color="Blue" Offset="0.333"/>
                    <GradientStop Color="Lime" Offset="0.667"/>
                    <GradientStop Color="Red" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Margin="1,1,1,1">
                <ScrollViewer Name="scroll" CanContentScroll="True" >
                    <ItemsControl Name="SongList" Margin="4, 4, 4, 4" ScrollViewer.VerticalScrollBarVisibility="Visible">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                    <Button
                                    Content="{Binding PlayOrPause}"
                                        Name="SongPlayOrPause"
                                        Width="30"
                                        Height="20"
                                        Margin="0,0,5,0"
                                    />
                                    <TextBlock Text="{Binding Title}" 
                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
