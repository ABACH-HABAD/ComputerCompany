<UserControl x:Class="ComputerCompany.Presentation.UserControls.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompany.Presentation.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="350" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="13*"/>
                <RowDefinition Height="4*"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="5,5,5,5">
                <TextBlock 
                Text="{Binding AccountName}"
                FontSize="30"
                Margin="5"/>
                <TextBlock
                Text="{Binding Status}" 
                FontSize="18"
                Margin="5"/>
                <TextBlock
                Text="{Binding Login}" 
                FontSize="18"
                Margin="5"/>
                <Button
                Command="{Binding ChangeNameCommand}"
                Name="ChangeDisplayName" 
                Content="Изменить имя профиля"
                HorizontalAlignment="Left" 
                FontSize="18"
                Margin="5" />
                <Button
                Command="{Binding ChangeLoginCommand}"
                Name="ChangeLogin" 
                Content="Изменить логин"
                HorizontalAlignment="Left" 
                FontSize="18"
                Margin="5" />
                <Button
                Command="{Binding ChangePasswordCommand}"
                Name="ChangePassword" 
                Content="Изменить пароль"
                HorizontalAlignment="Left" 
                FontSize="18"
                Margin="5" />
                <Button
                IsEnabled="False" Content="Мои заказы" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5"/>
                <Button 
                IsEnabled="False" Content="История заказов" HorizontalAlignment="Left" FontSize="18" Margin="5,5,5,5"/>
            </StackPanel>
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                <Button
                Command="{Binding LogoutCommand}"
                x:Name="Logout" 
                Content="Выйти" 
                HorizontalAlignment="Left"
                FontSize="18" 
                Margin="5,5,5,5"/>
                <Button 
                Command="{Binding DeleteAccountCommand}"
                x:Name="DeleteAccount"
                Content="Удалить аккаунт"
                HorizontalAlignment="Left" 
                FontSize="18"
                Margin="5,5,5,5"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="21*"/>
                <RowDefinition Height="13*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Bottom">
                    <TextBlock
                    Text="Оставить отзыв:" 
                    FontSize="18"
                    Margin="5,5,5,5"/>
                    <TextBlock 
                    x:Name="Stars" 
                    Text="{Binding DisplayStars}" 
                    FontSize="18"
                    Margin="5,5,5,5"
                    HorizontalAlignment="Left"/>
                    <Slider 
                    x:Name="StarSlider" 
                    Value="{Binding StarCount}"
                    Width="{Binding ElementName=Stars, Path=Width}" 
                    Maximum="5" Minimum="1"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <StackPanel Margin="10,10,10,10" Width="200" HorizontalAlignment="Right">
                        <Image x:Name="ProfileImage" Source="/Resources/Images/NoImage.png" Stretch="Fill" Width="150" Height="150" HorizontalAlignment="Center" Margin="5,5,5,5"/>
                        <Button
                        x:Name="ChangeImage" 
                        IsEnabled="False"
                        Content="Изменить фото" 
                        HorizontalAlignment="Stretch"
                        FontSize="18" 
                        Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox 
                Text="{Binding ReviewText}"
                x:Name="ReviewText" 
                FontSize="18"
                Grid.Row="0"
                HorizontalAlignment="Stretch" 
                Margin="5,5,5,0" 
                TextWrapping="Wrap" 
                VerticalAlignment="Top"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,5" Grid.Row="1" HorizontalAlignment="Right">
                    <Button 
                    Command="{Binding DeleteReviewCommand}"
                    Content="Удалить"
                    FontSize="18"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    MinHeight="20"
                    MinWidth="70" />
                    <Button 
                    Command="{Binding SendReviewCommand}"
                    Content="Отправить"
                    FontSize="18"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    MinHeight="20"
                    MinWidth="70" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
