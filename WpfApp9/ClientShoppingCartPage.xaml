<Page x:Class="ComputerCompanyClasses.ClientShoppingCartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompanyClasses"
      mc:Ignorable="d" 
              d:DesignHeight="350" d:DesignWidth="800"
      Loaded="Page_Loaded"
Title="Корзина">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="53*"/>
            <ColumnDefinition Width="26*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Margin="10,0,10,0" FontSize="25"> 🛒 Корзина</TextBlock>
            <Button x:Name="Clear" Content="Отчистить корзину" VerticalAlignment="Center" FontSize="25" Click="Clear_Click"/>
            <Button x:Name="Update" Content="Обновить" VerticalAlignment="Center" FontSize="25" Click="Update_Click"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="5,5,5,5">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="Red"/>
                    <GradientStop Color="Red" Offset="1"/>
                    <GradientStop Color="Blue" Offset="0.333"/>
                    <GradientStop Color="Lime" Offset="0.667"/>
                </LinearGradientBrush>
            </Grid.Background>
            <ScrollViewer Name="scroll" CanContentScroll="True" Margin="2,2,2,2">
                <ItemsControl Name="PurchaseList" Background="#FF252525">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,10,10,0" Height="100" VerticalAlignment="Top">
                                <Grid.Background>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                        <LinearGradientBrush.RelativeTransform>
                                            <TransformGroup>
                                                <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </LinearGradientBrush.RelativeTransform>
                                        <GradientStop Color="Red"/>
                                        <GradientStop Color="Red" Offset="1"/>
                                        <GradientStop Color="Blue" Offset="0.333"/>
                                        <GradientStop Color="Lime" Offset="0.667"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <Grid Margin="1,1,1,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Margin="5,5,5,5" Source="{Binding Image}"/>
                                    <TextBlock Text="{Binding Description}"  Grid.Column="1" Margin="5,5,5,5" TextWrapping="Wrap" FontSize="18"/>
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <WrapPanel Orientation="Horizontal">
                                            <TextBlock Text="Цена:" TextWrapping="Wrap" Padding="0,5,5,0" FontSize="20"/>
                                            <TextBlock Text="{Binding Price}" TextWrapping="Wrap" Padding="0,5,5,0" FontSize="20"/>
                                            <TextBlock Text="рублей" TextWrapping="Wrap" Padding="0,5,5,0" FontSize="20"/>
                                        </WrapPanel>
                                        <Button Grid.Row="1" 
                                                Name="DeleteButton"
                                                Content="Удалить" 
                                                VerticalAlignment="Bottom" 
                                                FontSize="20"
                                                HorizontalAlignment="Stretch"
                                                Click="DeleteButton_Click"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Column="1" Grid.Row="1" Margin="5,5,0,0">
            <TextBlock Text="Итого:" FontSize="20" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            <WrapPanel Orientation="Horizontal">
                <TextBlock x:Name="Total" FontSize="20" HorizontalAlignment="Left" Margin="5,5,5,5"/>
                <TextBlock Text="рублей" FontSize="20" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            </WrapPanel>
            <Button x:Name="CardPayButton" Content="Оплатить картой" VerticalAlignment="Center" FontSize="20" Margin="5,5,5,5" HorizontalAlignment="Left" Click="CardPayButton_Click"/>
            <Button x:Name="QRCodePayButton" Content="Оплатить через СБП" VerticalAlignment="Center" FontSize="20" Margin="5,5,5,5" HorizontalAlignment="Left" Click="QRCodePayButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
