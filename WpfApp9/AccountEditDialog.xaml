<Window x:Class="ComputerCompany.AccountEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Редактирование аккаунта" 
        Height="325" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Данные аккаунта:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Bottom"/>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="16*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Логин:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Center" HorizontalAlignment="Left" Height="43" Width="95"/>
            <TextBlock Grid.Row="1" Text="Имя:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Center" HorizontalAlignment="Left" Height="43" Width="73"/>
            <TextBlock Grid.Row="2" Text="Статус:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Center" HorizontalAlignment="Left" Height="43" Width="101"/>
            <TextBox Grid.Row="0" Grid.Column="1" Name="NewEmail" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5,5,10,5" FontSize="18"/>
            <TextBox Grid.Row="1" Grid.Column="1" Name="NewName" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5,5,10,5" FontSize="18"/>
            <TextBox Grid.Row="2" Grid.Column="1" Name="NewStatus" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="5,5,10,5" FontSize="18"/>
        </Grid>
        <Button Grid.Row="2" x:Name="DropImage" Grid.Column="1" Content="Сбросить фото профиля" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="DropImage_Click"/>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Accept" Content="Подтвердить" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Accept_Click"/>
            <Button x:Name="Cancel" Grid.Column="1" Content="Отмена" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
