<Page x:Class="ComputerCompanyClasses.ClientComponentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompanyClasses"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Комплектующие">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <StackPanel VerticalAlignment="Center" Margin="10,10,10,10" Orientation="Horizontal">
            <TextBlock Text="Выберите тип компонента:" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ComboBox Name="DataBaseSelector" Margin="10,0,0,0" Width="150" HorizontalAlignment="Center" DropDownClosed="DataBaseSelector_DropDownClosed"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="10,10,10,10">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Red" Offset="0"/>
                    <GradientStop Color="Blue" Offset="0.333"/>
                    <GradientStop Color="Lime" Offset="0.667"/>
                    <GradientStop Color="Red" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Margin="1,1,1,1">
                <ScrollViewer Name="scroll" CanContentScroll="True" >
                    <DataGrid x:Name="DataBaseGrid" 
                              AutoGenerateColumns="False" 
                              ItemsSource="{Binding BoundDataBase}" 
                              CanUserAddRows="False">
                        <DataGrid.Resources>
                            <Style x:Key="EditButtonStyle" 
                                   TargetType="Button">
                                <Setter Property="Background" Value="#FF303030"/>
                                <Setter Property="BorderBrush" >
                                    <Setter.Value>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                            <LinearGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                    <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                    <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                    <TranslateTransform/>
                                                </TransformGroup>
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Color="Red"/>
                                            <GradientStop Color="Red" Offset="1"/>
                                            <GradientStop Color="Blue" Offset="0.333"/>
                                            <GradientStop Color="Lime" Offset="0.667"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="border"
                                                        CornerRadius="5" 
                                                        Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#40000000"/>
                                                    </Border.Effect>
                                                </Border>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF404040"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF606060"/>
                                                    <Setter TargetName="border" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Color="#40000000"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AccountType}" Value="Admin">
                                        <Setter Property="Background" Value="#FF464646"/>
                                        <Setter Property="Foreground" Value="#FFC85F5F"/>
                                        <Setter Property="BorderBrush" Value="#FFC85F5F"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="ToolTip" Value="Нельзя изменить данный аккаунт"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="Price" Header="Цена" Binding="{Binding Path=Price}"/>
                            <DataGridTextColumn x:Name="Count" Header="Количество" Binding="{Binding Path=Count}"/>
                            <DataGridTemplateColumn x:Name="Actions" Header="Действия" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="В корзину" 
                                                Style="{StaticResource EditButtonStyle}"
                                                x:Name="BuyButton"
                                                Click="BuyButton_Click"
                                                Margin="5" Height="22"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
