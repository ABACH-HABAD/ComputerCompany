<Window x:Class="ComputerCompany.InformationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        Title="InformationWindow" Height="500" Width="500" >
    <Grid>
        <ScrollViewer Margin="20">
            <TextBlock Margin="5" x:Name="Text" FontSize="20" TextAlignment="Justify" TextWrapping="Wrap" >Some Text</TextBlock>
        </ScrollViewer>
    </Grid>
</Window>
