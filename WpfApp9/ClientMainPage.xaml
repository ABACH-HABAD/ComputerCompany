<Page x:Class="ComputerCompanyClasses.ClientMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ComputerCompanyClasses"
      mc:Ignorable="d" 
      d:DesignHeight="350" d:DesignWidth="800"
      Title="Главная">
    <Grid Margin="5,5,5,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0">Услуги и товары: 🗑︎</TextBlock>
            <Grid>
                <TextBox TextChanged="Search_TextChanged" x:Name="Search" VerticalAlignment="Center" HorizontalAlignment="Left" Width="400" FontSize="25" Height="30" Margin="10,0,0,0" />
                <TextBlock Foreground="#FF8E8E8E"
                           MaxWidth="{Binding ActualWidth, ElementName=Search}"
                           Text="Поиск 🔎"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Left" 
                           Width="400" 
                           FontSize="25" 
                           Height="30" 
                           Margin="15,0,0,5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsKeyboardFocused, ElementName=Search}"
                                       Value="False"/>
                                        <Condition Binding="{Binding Text, ElementName=Search}"
                                       Value="{x:Static sys:String.Empty}"
                                       xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>
        <Grid Name="AllServices" Grid.Row="1" Margin="20,5,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <Style TargetType="Button" x:Key="serviceStyle">
                    <Setter Property="Margin" Value="5,5,5,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Border x:Name="border"
                                                    CornerRadius="15"
                                                    Background="#FF303030" 
                                                    BorderThickness="3">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                                <LinearGradientBrush.RelativeTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                        <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                        <TranslateTransform/>
                                                    </TransformGroup>
                                                </LinearGradientBrush.RelativeTransform>
                                                <GradientStop Color="Red"/>
                                                <GradientStop Color="Red" Offset="1"/>
                                                <GradientStop Color="Blue" Offset="0.333"/>
                                                <GradientStop Color="Lime" Offset="0.667"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#40000000"/>
                                        </Border.Effect>
                                        <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" VerticalAlignment="Bottom" Margin="0,0,0,15" FontSize="20" TextAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="borderImageShadow"
                                                    CornerRadius="15"
                                                    Background="#FF303030" 
                                                    BorderThickness="3" Margin="10,10,10,70">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                                <LinearGradientBrush.RelativeTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                        <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                        <TranslateTransform/>
                                                    </TransformGroup>
                                                </LinearGradientBrush.RelativeTransform>
                                                <GradientStop Color="Red"/>
                                                <GradientStop Color="Red" Offset="1"/>
                                                <GradientStop Color="Blue" Offset="0.333"/>
                                                <GradientStop Color="Lime" Offset="0.667"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#40000000"/>
                                        </Border.Effect>
                                    </Border>
                                    <Border x:Name="imageBorder"
                                                    CornerRadius="15"
                                                    BorderThickness="3" Margin="10,10,10,70">
                                        <Border.Background>
                                            <ImageBrush x:Name="ProductImage" 
                                                        ImageSource="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Stretch="Fill"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" SpreadMethod="Pad">
                                                <LinearGradientBrush.RelativeTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                                                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                                                        <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                                                        <TranslateTransform/>
                                                    </TransformGroup>
                                                </LinearGradientBrush.RelativeTransform>
                                                <GradientStop Color="Red"/>
                                                <GradientStop Color="Red" Offset="1"/>
                                                <GradientStop Color="Blue" Offset="0.333"/>
                                                <GradientStop Color="Lime" Offset="0.667"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FF404040"/>
                                        <Setter TargetName="borderImageShadow" Property="Background" Value="#FF404040"/>
                                        <Setter TargetName="imageBorder" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FF606060"/>
                                        <Setter TargetName="borderImageShadow" Property="Background" Value="#FF606060"/>
                                        <Setter TargetName="imageBorder" Property="Opacity" Value="0.6"/>
                                        <Setter TargetName="border" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Color="#40000000"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <Button Name="Building" Grid.Column="0" Content="Сборка ПК" Style="{StaticResource serviceStyle}" Tag="/Resources/Images/Building.png" Click="Building_Click"/>
            <Button Name="Upgrade" Grid.Column="1" Content="Апгрейд ПК" Style="{StaticResource serviceStyle}" Tag="/Resources/Images/Upgrade.png" Click="Upgrade_Click"/>
            <Button Name="Repair" Grid.Column="2" Content="Починка ПК" Style="{StaticResource serviceStyle}" Tag="/Resources/Images/Repair.png" Click="Repair_Click"/>
            <Button Name="Component" Grid.Column="3" Content="Комплектующие" Style="{StaticResource serviceStyle}" Tag="/Resources/Images/Component.png" Click="Component_Click"/>
        </Grid>
    </Grid>
</Page>
