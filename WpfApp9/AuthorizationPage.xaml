<Page x:Class="ComputerCompanyClasses.AuthorizationPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="ComputerCompany:WpfApp9"
        mc:Ignorable="d"
      ShowsNavigationUI="False"
        Title="AuthorizationPage" Height="400" Width="700" HorizontalAlignment="Center" VerticalAlignment="Center">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Авторизация"  VerticalAlignment="Top"/>
        <Label Content="Логин (эл. почта):" HorizontalAlignment="Left" Margin="35,5,0,5" />
        <TextBox  VerticalAlignment="Top" Width="120" Name="Login"/>
            <Label Content="Пароль:"  VerticalAlignment="Top" HorizontalAlignment="Left" Margin="35,5,0,5" />
            <PasswordBox  VerticalAlignment="Top" Width="120" Name="Password"/>

        <Button Name="Authorization" Content="Авторизация" Margin="0,80,0,0" Width="200" Height="25" Click="Authorization_Click"/>
        <Button Name="Registration" Content="Создать аккаунт" Margin="0,10,0,0" Width="125" Height="25" Click="Registration_Click"/>

        </StackPanel>
</Page>
