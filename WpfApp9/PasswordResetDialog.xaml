<Window x:Class="ComputerCompany.PasswordResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Смена пароля" Height="150" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Введите новый пароль:" FontSize="20" Padding="10,10,10,10" VerticalAlignment="Bottom"/>
        <TextBox Grid.Row="1" Name="NewPassword" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="10,0,10,0" FontSize="18"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="Accept" Content="Подтвердить" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Accept_Click"/>
            <Button x:Name="Cancel" Grid.Column="1" Content="Отмена" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="20" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
