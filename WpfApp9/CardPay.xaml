<Window x:Class="ComputerCompany.CardPay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComputerCompany"
        mc:Ignorable="d"
        Title="Оплата картой" Height="500" Width="400">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock  Text="Номер карты" FontSize="20" Margin="0,15,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBox Width="75" Margin="5,0,5,0" FontSize="20" Height="25" />
                <TextBox Width="75" Margin="5,0,5,0" FontSize="20" Height="25" />
                <TextBox Width="75" Margin="5,0,5,0" FontSize="20" Height="25" />
                <TextBox Width="75" Margin="5,0,5,0" FontSize="20" Height="25" />
            </StackPanel>
            <TextBlock  Text="Срок действия карты" FontSize="20" Margin="0,15,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="10">
                <TextBox Width="50" Margin="5,0,5,0" FontSize="20" Height="25" />
                <TextBlock  Text="/" FontSize="20" Margin="5,0,5,0"  />
                <TextBox Width="50" Margin="5,0,5,0" FontSize="20" Height="25" />
            </StackPanel>
            <TextBlock  Text="Имя владельца" FontSize="20" Margin="0,15,0,5"/>
            <TextBox Margin="15,10,15,10" FontSize="20" Height="25" HorizontalAlignment="Stretch" />
            <TextBlock  Text="CVV/CVC" FontSize="20" Margin="0,15,0,5"/>
            <TextBox Margin="15,10,15,10" FontSize="20" Height="25" HorizontalAlignment="Left" Width="75" />
            <Button Name="Pay" Margin="15,15,15,5" FontSize="20" Height="25" HorizontalAlignment="Stretch" Content="Оплатить" Click="Pay_Click" />
        </StackPanel>
    </Grid>
</Window>
